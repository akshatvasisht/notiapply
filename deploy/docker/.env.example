# Copy to .env and fill in. Generate random secrets with: openssl rand -hex 32

# Postgres
POSTGRES_USER=notiapply
POSTGRES_PASSWORD=
POSTGRES_DB=notiapply

# n8n
# 32-byte hex; changing this invalidates all stored credentials in n8n
N8N_ENCRYPTION_KEY=
# URL you actually reach n8n on. This MUST match the URL in your browser and
# the URL the Tauri app is configured to use — mismatches cause n8n to
# generate webhook URLs pointing at the wrong host, and the Webhook trigger
# nodes will look "registered" but never fire for external callers.
#   Local dev (laptop all-in-one):  http://localhost:5678
#   VPS via Tailscale Serve:        https://<host>.<tailnet>.ts.net
N8N_EDITOR_BASE_URL=http://localhost:5678
# IANA tz name (e.g. America/Los_Angeles). Affects cron trigger interpretation.
GENERIC_TIMEZONE=UTC

# Shared secret the Tauri app sends as X-Webhook-Secret header and workflows validate
NOTIAPPLY_WEBHOOK_SECRET=
